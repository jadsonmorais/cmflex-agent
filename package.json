{
  "name": "cmflex-erp-agent",
  "version": "1.0.0",
  "description": "Agente de automação do ERP CMFlex via Playwright",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:setup": "playwright test --project=setup",
    "warmup": "playwright test tests/warmup.spec.ts --project=cmflex",
    "warmup:headed": "playwright test tests/warmup.spec.ts --project=cmflex --headed"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@types/node": "^22.0.0"
  },
  "dependencies": {
    "dotenv": "^16.4.0"
  }
}
